    <nav.item @label="Quickstart" @route="docs.index" />
    <nav.item @label="Stability & Support" @route="docs.stability-and-support" />

    <nav.section @label="Usage" />

    <nav.item @label="Native Class Basics" @route="docs.native-class-basics" />
    <nav.item @label="Class Fields" @route="docs.class-fields" />
    <nav.item @label="Decorators" @route="docs.decorators" />
