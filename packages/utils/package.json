{
  "name": "@ember-decorators/utils",
  "version": "6.1.1",
  "description": "Utilities used by the Ember Decorators project",
  "keywords": [
    "ember-addon"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/ember-decorators/ember-decorators.git"
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./addon-main.js": "./addon-main.cjs",
    "./*": {
      "default": "./dist/*.js"
    }
  },
  "files": [
    "addon-main.cjs",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup --config",
    "prepack": "rollup --config",
    "lint:publish": "pnpm build && publint run --level error"
  },
  "dependencies": {
    "@embroider/addon-shim": "^1.8.9",
    "decorator-transforms": "^2.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@embroider/addon-dev": "^8.1.0",
    "@embroider/compat": "^4.1.0",
    "@embroider/core": "^4.1.0",
    "@embroider/macros": "^1.20.1",
    "@rollup/plugin-babel": "^6.0.4",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "publint": "^0.3.16",
    "rollup": "^4.22.5"
  },
  "ember-addon": {
    "version": 2,
    "type": "addon",
    "main": "addon-main.cjs"
  }
}
