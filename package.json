{
  "name": "@ember-decorators/ember-decorators",
  "private": true,
  "description": "Core library for Ember Decorators",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r build && pnpm --filter ember-decorators test",
    "start": "pnpm --filter ember-decorators start",
    "start:docs": "pnpm --filter ember-decorators-docs start"
  },
  "engines": {
    "node": ">= 18"
  },
  "pnpm": {
    "packageExtensions": {
      "ember-cli-clipboard": {
        "dependencies": {
          "@glimmer/component": "^1.1.2",
          "@glimmer/tracking": "^1.1.2"
        }
      },
      "ember-tether": {
        "dependencies": {
          "@glimmer/component": "^1.1.2",
          "@glimmer/tracking": "^1.1.2"
        }
      }
    }
  },
  "packageManager": "pnpm@10.33.0"
}
