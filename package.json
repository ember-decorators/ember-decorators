{
  "name": "@ember-decorators/ember-decorators",
  "private": true,
  "description": "Core library for Ember Decorators",
  "repository": {
    "type": "git",
    "url": "git@github.com:ember-decorators/ember-decorators.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter './packages/*' build",
    "lint": "eslint .",
    "build": "pnpm -r build",
    "test": "pnpm -r build && pnpm --filter ember-decorators test",
    "start": "pnpm --filter ember-decorators start",
    "start:docs": "pnpm --filter ember-decorators-docs start",
    "test": "pnpm --filter ember-decorators test",
    "build": "pnpm --filter './packages/*' build"
  },
  "devDependencies": {
    "babel-eslint": "^10.0.0",
    "eslint": "^5.0.0",
    "eslint-plugin-ember": "^7.0.0",
    "eslint-plugin-node": "^11.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">= 18"
  },
  "pnpm": {
    "packageExtensions": {
      "ember-cli-clipboard": {
        "dependencies": {
          "@glimmer/component": "^1.1.2",
          "@glimmer/tracking": "^1.1.2"
        }
      },
      "ember-tether": {
        "dependencies": {
          "@glimmer/component": "^1.1.2",
          "@glimmer/tracking": "^1.1.2"
        }
      }
    }
  }
}
